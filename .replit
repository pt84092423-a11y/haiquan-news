modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd haiquan-news && npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5050
externalPort = 3002

[[ports]]
localPort = 19865
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
build = ["bash", "-c", "cd haiquan-news && npm install && PORT=5000 npm run build"]
publicDir = "haiquan-news/dist"
run = ["node", "haiquan-news/server.js"]
